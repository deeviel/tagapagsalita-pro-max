    "autoprefixer": "^10.4.21",
    "discord.js": "^14.26.4",
    "dotenv": "^17.2.3",
    "edge-tts-universal": "^1.4.0",
    "esbuild": "^0.25.0",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.3.0",
    "google-tts-api": "^2.0.2",
    "libsodium-wrappers": "^0.8.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-edge-tts": "^1.2.10",
    "opusscript": "^0.0.8",
    "play-dl": "^1.9.7",
    "postcss": "^8.4.38",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwindcss": "3.4.17",
