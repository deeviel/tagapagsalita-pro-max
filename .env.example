# ------------------------------------------------------------------------------
# Production Environment Configuration (e.g. for CloudPanel)
# ------------------------------------------------------------------------------

# NODE_ENV: Set to "production" to optimize Vite serving and performance.
NODE_ENV="production"

# PORT: The port the Node.js Express server runs on. CloudPanel reverse proxies to this port.
PORT="3001"

# DISCORD_TOKEN: Your Discord Bot Token (Go to https://discord.com/developers/applications)
DISCORD_TOKEN=""

# DISCORD_MUSIC_TOKEN: Your Discord Music Bot Token
DISCORD_MUSIC_TOKEN=""

# SPOTIFY_CLIENT_ID: Spotify Application Client ID (Optional, for Spotify Playlists/Albums retrieval)
SPOTIFY_CLIENT_ID=""

# SPOTIFY_CLIENT_SECRET: Spotify Application Client Secret (Optional, for Spotify Playlists/Albums retrieval)
SPOTIFY_CLIENT_SECRET=""
